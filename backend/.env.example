# Copy to backend/.env for local overrides.
# Prefer keeping Rscript on PATH instead of using a machine-specific absolute path.
R_EXECUTABLE=Rscript
USE_PARQUET=true
# Persistent production path, for example /home/proteomicsviz/data/reports
# REPORTS_DIR=backend/reports
# For the private UI reached through the documented SSH tunnel:
# CORS_ORIGINS=["http://127.0.0.1:8001","http://localhost:8001"]
