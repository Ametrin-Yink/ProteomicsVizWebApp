# Install as /etc/proteomicsviz/backend.env with mode 0640 and ownership
# root:proteomicsviz. This syntax is compatible with systemd EnvironmentFile.

DEBUG=false
R_EXECUTABLE=/usr/bin/Rscript
USE_PARQUET=true
MAX_UPLOAD_SIZE_MB=500

SESSIONS_DIR=/home/proteomicsviz/data/sessions
REPORTS_DIR=/home/proteomicsviz/data/reports
FILE_LIBRARY_DIR=/home/proteomicsviz/data/file-library
PROTEIN_DATABASE_DIR=/home/proteomicsviz/data/protein-database

# The outer single quotes preserve the JSON string for pydantic-settings.
CORS_ORIGINS='["http://127.0.0.1:8001","http://localhost:8001"]'

# Conservative starting point for a 16-core/32-thread server. Tune from
# observed production workloads instead of raising both dimensions at once.
MSSTATS_MAX_WORKERS=4
MSSTATS_N_CORES_CAP=4
MSQROB2_MAX_WORKERS=4
MSQROB2_N_CORES_CAP=4
