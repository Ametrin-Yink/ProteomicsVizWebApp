# Install as /etc/proteomicsviz/frontend.env with mode 0640 and ownership
# root:proteomicsviz. The deployment script also sources this file while
# building Next.js because NEXT_PUBLIC_* values are embedded at build time.

BACKEND_URL=http://127.0.0.1:8100
NEXT_PUBLIC_REPORT_BASE_URL=http://10.202.25.39:8000

# Leave NEXT_PUBLIC_API_URL and NEXT_PUBLIC_WS_URL unset. The private Windows
# client reaches their localhost defaults through the two documented SSH
# tunnels, while shared report clients use same-origin relative API paths.
